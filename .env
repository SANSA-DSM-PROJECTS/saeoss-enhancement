# ============================================
# NGINX Configuration
# ============================================
NGINX_HTTP_PORT=8085
NGINX_HTTPS_PORT=443
NGINX_CPU_LIMIT=1
NGINX_MEMORY_LIMIT=512M

# ============================================
# GeoServer Configuration
# ============================================
GEOSERVER_PORT=8080
GEOSERVER_CPU_LIMIT=2
GEOSERVER_MEMORY_LIMIT=4G
GEOSERVER_DATA_PATH=/home/alamba/Documents/Projects/Data
GEOSERVER_ADMIN_USER=alamba
GEOSERVER_ADMIN_PASSWORD=lamba
GEOSERVER_JAVA_OPTS=-Xms1g -Xmx3g -XX:ParallelGCThreads=2 -XX:ConcGCThreads=2 -Dorg.geotools.referencing.forceXY=true
GEOSERVER_EXTRA_JAVA_OPTS=-Xms1g -Xmx3g -Djavax.servlet.request.encoding=UTF-8 -Djavax.servlet.response.encoding=UTF-8 -Dfile.encoding=UTF8
GEOSERVER_PRODUCTION=true
GEOSERVER_ENABLE_JSONP=true
GEOSERVER_PROXY_BASE_URL=http://localhost:8080/geoserver
GEOSERVER_CSRF_WHITELIST=http://localhost:8080

# ============================================
# PostgreSQL Configuration
# ============================================
POSTGRES_HOST_AUTH_METHOD=trust
POSTGRES_DB=datastore
POSTGRES_USER=alamba
POSTGRES_PASSWORD=lamba
POSTGRES_SHARED_BUFFERS=512MB
POSTGRES_EFFECTIVE_CACHE_SIZE=1536MB
POSTGRES_WORK_MEM=16MB

# ============================================
# Redis Configuration
# ============================================
REDIS_CPU_LIMIT=0.5
REDIS_MEMORY_LIMIT=256M
REDIS_MAX_MEMORY=128mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ============================================
# Laravel Configuration
# ============================================
LARAVEL_CPU_LIMIT=1.5
LARAVEL_MEMORY_LIMIT=1G
OPCACHE_ENABLE=1
OPCACHE_MEMORY_CONSUMPTION=128
OPCACHE_MAX_FILES=10000
OPCACHE_REVALIDATE_FREQ=60

# ============================================
# Logging Configuration
# ============================================
LOG_MAX_SIZE=10m
LOG_MAX_FILES=3

# ============================================
# Healthcheck Configuration
# ============================================
HEALTHCHECK_INTERVAL=30s
HEALTHCHECK_TIMEOUT=10s
HEALTHCHECK_RETRIES=3

# ============================================
# Docker Compose
# ============================================
COMPOSE_REPLICA=1

# ============================================
# SMTP Configuration
# ============================================
MAIL_MAILER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=mabheka@gmail.com"
MAIL_PASSWORD=kqdkhbhbfcefcciz
MAIL_ENCRYPTION=null 
MAIL_FROM_ADDRESS="mabheka@gmail.com"
MAIL_FROM_NAME="${APP_NAME}"
